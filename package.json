{
  "name": "nidan-lab",
  "version": "1.0.0",
  "description": "Nidan Laboratory Management System",
  "author": "Fenyxn Lab",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.nidanlab.lms",
    "productName": "Nidan Lab",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nidan Lab"
    },
    "publish": {
      "provider": "github",
      "owner": "Fenyxn",
      "repo": "laboratory_release"
    }
  },
  "dependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
